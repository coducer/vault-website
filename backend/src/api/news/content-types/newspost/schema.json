{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "newspost",
    "pluralName": "news",
    "displayName": "News",
    "description": "Create news content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "bgImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "date": {
      "type": "datetime"
    }
  }
}
